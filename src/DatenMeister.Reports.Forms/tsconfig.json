{
  "compilerOptions": {
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": true,
    "target": "ES2020",
    "module": "ES2020",
    "paths": {
      "/js/datenmeister/*": [ "../Web/DatenMeister.WebServer/wwwroot/js/datenmeister/*" ],
      "module/*": [ "./Js/*" ]
    },
    "types": ["jquery"]
  },
  "compileOnSave": true,
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "bin",
    "obj"
  ]
}