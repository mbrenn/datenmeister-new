{
  "compilerOptions": {
    "noImplicitAny": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "strictPropertyInitialization": false,
    "types": [ "chai", "mocha", "jquery", "jquery.fancytree" ]
  },
  "compileOnSave": true,
  "exclude": [
    "bin",
    "obj"
  ],
  "include": [
    "**/*.ts"
  ]
}
