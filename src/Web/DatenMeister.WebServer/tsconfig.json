{
  "compilerOptions": {
    "noImplicitAny": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16"
  },
  "compileOnSave": true,
  "exclude": [
    "node_modules",
    "bin",
    "obj"
  ],
  "include": [
    "**/*.ts"
  ],
  "types": [ 
    "chai" 
  ]
}
